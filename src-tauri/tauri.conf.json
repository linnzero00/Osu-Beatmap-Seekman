{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Osu! Beatmap Seekman",
  "version": "2.0.2",
  "identifier": "com.linnzero00.osubeatmapseekman",
  "build": {
    "beforeDevCommand": "npm run vite:dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Osu! Beatmap Seekman",
        "width": 1240,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
