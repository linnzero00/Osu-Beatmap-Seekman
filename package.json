{
  "name": "osu-beatmap-seekman",
  "version": "1.0.2",
  "private": true,
  "description": "Desktop downloader for ranked osu! beatmapsets with filters, de-duplication, progress, and resume support.",
  "type": "module",
  "scripts": {
    "dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri dev",
    "vite:dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "tauri": "tauri",
    "tauri:build": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri build",
    "tauri:android:init": "tauri android init",
    "tauri:android:build": "tauri android build --apk",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "4.3.4",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "5.7.3",
    "vite": "5.4.19"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5"
  }
}
